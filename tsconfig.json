{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2023", "DOM"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"types": ["bun-types"]
	},
	"include": ["src/**/*"]
}
